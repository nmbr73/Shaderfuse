    }

    InColorAColorR = self:AddInput("Red",   "ColorARed",   { INP_Default  = 0.50, IC_ControlID = 0, attrs})
    InColorAColorG = self:AddInput("Green", "ColorAGreen", { INP_Default  = 0.38, IC_ControlID = 1, attrs})
