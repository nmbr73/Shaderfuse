    }

    InColorBColorR = self:AddInput("Red",   "ColorBRed",   { INP_Default  = 0.50, IC_ControlID = 0, attrs})
    InColorBColorG = self:AddInput("Green", "ColorBGreen", { INP_Default  = 0.35, IC_ControlID = 1, attrs})
    InColorBColorB = self:AddInput("Blue",  "ColorBBlue",  { INP_Default  = 0.25, IC_ControlID = 2, attrs})
    InColorBColorA = self:AddInput("Alpha", "ColorBAlpha", { INP_Default  = 1.0, IC_ControlID = 3, attrs})

  self:EndControlNest()

  self:BeginControlNest("ColorC", "ColorC", true, {})

    ctrl_grp_cnt = (ctrl_grp_cnt==nil) and 1 or (ctrl_grp_cnt+1)

    attrs = {
      ICS_Name = "ColorC",
      LINKID_DataType = "Number",
      INPID_InputControl = "ColorControl",
