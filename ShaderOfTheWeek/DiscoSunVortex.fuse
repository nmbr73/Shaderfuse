    }

    InColorCColorR = self:AddInput("Red",   "ColorCRed",   { INP_Default  = 1.0, IC_ControlID = 0, attrs})
    InColorCColorG = self:AddInput("Green", "ColorCGreen", { INP_Default  = 1.0, IC_ControlID = 1, attrs})
