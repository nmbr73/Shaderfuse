          INP_MinScale       = -1.0,
          INP_MaxScale       = 2.0,
          INP_Default        = 0.2,
      })

  InTURNTABLE_SPEED2Slider = self:AddInput("TURNTABLE_SPEED2", "TURNTABLE_SPEED2", {
          LINKID_DataType    = "Number",
          INPID_InputControl = "SliderControl",
          INP_MinScale       = -1.0,
          INP_MaxScale       = 2.0,
          INP_Default        = 0.0667,
      })

  InTURNTABLE_DEPTHSlider = self:AddInput("TURNTABLE_DEPTH", "TURNTABLE_DEPTH", {
          LINKID_DataType    = "Number",
          INPID_InputControl = "SliderControl",
          INP_MinScale       = -1.0,
