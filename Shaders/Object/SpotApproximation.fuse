/*
    This file contains the Spot approximation functions and related definitions.

    Raymarching and rendering demo code is in "shadertoy_image_shader.glsl"

*/


// Define this to enable an optimized version of the signed distance function
// May be less efficient for incoherent rays in path tracing
//#define SPOT_SDF_OPTIMIZED

// The optimized version may slightly overestimate distances.
// If this is an issue, change the constant below to (e.g.) 0.99
//const float SPOT_SDF_OPTIMIZED_SCALE = 1.0f;

// Define this to make the spot_get_color_index function return a signed value and gradient as well as the color index
// Value and gradient can be used for antialiasing.
// For path tracing, you would probably not use this
// When defined, spot_get_eye_highlight_grad must be called to test the eye highlight shape.
#define SPOT_TEXTURE_EDGE_GRADIENT

// Coordinates of AABB of the Spot approximation shape
// (slightly larger than bound taken from a large number of samples)
// TODO: Find actual bound using gradient descent at extreme points



// Values used to represent colors
#define SPOT_COLOR_BASE    0
#define SPOT_COLOR_SPOTS   1
#define SPOT_COLOR_NOSE    2
#define SPOT_COLOR_UDDER   3 // same color as nose
#define SPOT_COLOR_HOOVES  4
#define SPOT_COLOR_HORNS   5
#define SPOT_COLOR_EYES    6
#define SPOT_COLOR_EYE_HIGHLIGHT  7
#define SPOT_COLOR_EARS    8
#define SPOT_COLOR_NOSTRILS  9

// Map a color index to a diffuse color
// Colors are taken from the original Spot texture SVG file, converted from sRGB to linear
__DEVICE__ float3 spot_color_index_to_rgb(int color_index, float3 Colors[9], float3 P, float3 N, float ratio, bool Tex, __TEXTURE2D__ iChannel0) {

    switch (color_index) {

    case SPOT_COLOR_SPOTS:
        return Colors[0];//to_float3_s(0.051f);
        //return swi3(texture(iChannel0, swi2(P,x,y)),x,y,z);

    case SPOT_COLOR_NOSE:
    case SPOT_COLOR_UDDER:
        return Colors[1];//to_float3(1.0f, 0.564f, 0.387f);

    case SPOT_COLOR_HOOVES:
        return Colors[2];//to_float3_s(0.138f);

    case SPOT_COLOR_HORNS:
        return Colors[3];//to_float3(0.337f, 0.102f, 0.036f);

    case SPOT_COLOR_EYES:
        return Colors[4];//to_float3_s(0.03f);

    case SPOT_COLOR_EYE_HIGHLIGHT:
        return Colors[5];//to_float3_s(1);

    case SPOT_COLOR_EARS:
        return Colors[6];//to_float3_s(0.337f);

    case SPOT_COLOR_NOSTRILS:
        return Colors[7];//to_float3(0.234f, 0.068f, 0.023f);

    //case SPOT_COLOR_BASE:
    default:
        //return to_float3(1.0f, 0.855f, 0.792f);
        //return swi3(texture(iChannel0, swi2(P,x,y)),x,y,z);
        if(Tex) return tex3D(iChannel0, P, N, ratio);
        else    return Colors[8];
        //return Tex == true ? tex3D(iChannel0, P, N, ratio) : Colors[8];
    }
}

// Quartic "smooth minimum" blending function for 2D SDF blending
// Blends two vec3s which have 2D gradient in xy and signed distance in z
// "dist" is a blending distance parameter
//      (if difference between the values is greater than this, then the minimum will be used)
// "q" controls the shape of the blending. Valid range is 0.125...0.59
//      q values outside of this range will cause the blended SDF to be invalid (no longer a bound of the true SDF)
//      values > 0.23f will cause a bulge between the two shapes.
//      Value of 1/6 sets the quartic coefficient to 0 (equivalent to cubic smooth min)
// If dist and q are constants then most of the calculations should occur at compile time, and it should be relatively cheap
//      (this is not the case for the texture function evaluation though).
__DEVICE__ float3 blend_smin(float3 f1, float3 f2, float dist, float q) {
    float x = f1.z;
    float y = f2.z;

    float s = 1.0f / dist;
    float s2 = s*s;

    float A = (3.0f*q - 0.5f) * s2 * s;
    float B = (-4.0f*q + 0.5f) * s2;

    float a = _fmaxf(dist - _fabs(x-y), 0.0f);

    A *= a;

    float t = (-4.0f*A - 3.0f*B) * a*a;

    return to_float3_aw(_mix(swi2(f1,x,y), swi2(f2,x,y), x < y ? t : 1.0f - t), _fminf(x, y) + (A + B) * a*a*a);
}

// Quartic "smooth minimum" or "smooth maximum" blending function for 3D SDF blending (see above)
// Blends two vec4s which have 3D gradient in xyz and signed distance in w
// If dist and q are constants then most of the calculations should occur at compile time, and it should be relatively cheap.
__DEVICE__ float4 blend_sminmax(float4 f1, float4 f2, float dist, float q, bool use_min) {
    float x = f1.w;
    float y = f2.w;

    float s = 1.0f / dist;
    float s2 = s*s;

    float A = (3.0f*q - 0.5f) * s2 * s;
    float B = (-4.0f*q + 0.5f) * s2;

    float a = _fmaxf(dist - _fabs(x-y), 0.0f);

    A *= a;

    float t = (-4.0f*A - 3.0f*B) * a*a;

    if (use_min) {
        return to_float4_aw(_mix(swi3(f1,x,y,z), swi3(f2,x,y,z), x < y ? t : 1.0f - t), _fminf(x, y) + (A + B) * a*a*a);
    } else {
        return to_float4_aw(_mix(swi3(f1,x,y,z), swi3(f2,x,y,z), x > y ? t : 1.0f - t), _fmaxf(x, y) - (A + B) * a*a*a);
    }
}

// Quartic "smooth minimum" blending function for 3D SDF blending (see above)
__DEVICE__ float4 blend_smin_f4(float4 f1, float4 f2, float dist, float q) {
    return blend_sminmax(f1, f2, dist, q, true);
}

// Quartic "smooth maximum" blending function for 3D SDF blending (see above)
__DEVICE__ float4 blend_smax(float4 f1, float4 f2, float dist, float q) {
    return blend_sminmax(f1, f2, dist, q, false);
}

// Signed distance function for sphere
__DEVICE__ float4 sdf_sphere(float3 P, float3 C, float r) {
    P = P - C;
    return to_float4_aw(normalize(P), length(P)-r);
}

// Signed distance function for half-space defined by a plane (normal vector and distance)
// Everything on one side of the plane is inside the shape.
__DEVICE__ float4 sdf_halfspace(float3 P, float3 V, float d) {
    return to_float4_aw(V, dot(P, V) - d);
}

// Signed distance function for a cylinder that extends infinitely in the x direction
__DEVICE__ float4 sdf_xcylinder(float3 P, float2 C, float r) {
    float2 Q = swi2(P,y,z) - C;

    float2 _Q = normalize(Q);

    return to_float4_aw(to_float3(0, _Q.x, _Q.y), length(Q)-r);
}

// Convenience function for cumulative SDF blending.
// Takes an SDF value and gradient and blends it with a sphere.
__DEVICE__ float4 blend_sphere(float4 f, float3 P, float3 C, float r, float dist, float q) {
    return blend_smin_f4(f, sdf_sphere(P, C, r), dist, q);
}

// Convenience function for blending a pair of spheres, mirrored across the x=0 plane
__DEVICE__ float4 sphere_pair(float3 P, float3 C, float r, float dist_pair, float q_pair) {
    return blend_smin_f4(sdf_sphere(P, C, r), sdf_sphere(P, C*to_float3(-1,1,1), r), dist_pair, q_pair);
}

// Convenience function for cumulative SDF blending.
// Takes an SDF value and gradient and blends it with a pair of spheres, mirrored across the x=0 plane
__DEVICE__ float4 blend_sphere_pair(float4 f, float3 P, float3 C, float r, float dist_pair, float q_pair, float dist, float q) {
    return blend_smin_f4(f, sphere_pair(P, C, r, dist_pair, q_pair), dist, q);
}

// Ellipse function that is not an SDF (or bound) but will be treated like an SDF for blending.
// Used for making blobbly 2D shapes, not for ray marching.
// Returns 2d gradient in xy, signed "distance" value in z.
__DEVICE__ float3 ellipse_function(float2 P, float3 M, float r) {
    float2 E = mul_mat2_f2(to_mat2(M.x, M.y, M.y, M.z) , P);

    float d = _sqrtf(dot(P, E));

    return to_float3_aw(1.0f/d * E, d - r);
}


//#ifndef SPOT_SDF_OPTIMIZED // use straightforward version of signed distance function

// "SDF" function (bound) for the Spot approximation.
// Returns gradient in xyz and distance (lower bound) in w
// IMPORTANT: Since this is not a true SDF, you need to normalize the gradient before using it as a normal vector.
__DEVICE__ float4 spot_sdf_and_gradient(float3 P) {
    float x_sign = P.x < 0.0f ? -1.0f : 1.0f;

    float4 f = sphere_pair(P, to_float3(0.09054f, -0.06191f, 0.7222f), 0.1924f, 0.2536f, 0.2769f); // body rear
    f = blend_sphere_pair(f, P, to_float3(0.2373f, -0.3205f, 0.3429f), -0.00176f, 0.1056f, 0.4102f, 0.6691f, 0.2359f); // body mid lower
    f = blend_sphere_pair(f, P, to_float3(-0.05041f, 0.1178f, 0.1419f), 0.167f, 0.05f, 0.125f, 0.7952f, 0.1992f); // body mid upper
    f = blend_sphere(f, P, to_float3(0, 0.00405f, 0.04695f), 0.1007f, 0.1422f, 0.59f); // chest
    f = blend_sphere(f, P, to_float3(0, 0.4546f, -0.2041f), 0.2553f, 0.1301f, 0.23f); // head mid
    f = blend_sphere_pair(f, P, to_float3(0.09402f, 0.651f, -0.408f), 0.1293f, 0.1836f, 0.23f, 0.15f, 0.22f); // head top front
    f = blend_sphere(f, P, to_float3(0, 0.7061f, -0.1507f), 0.01744f, 0.2003f, 0.2578f); // head top back
    f = blend_smax(f, sdf_halfspace(P, to_float3(0, 0.1445f, -0.9895f), 0.5541f), 0.1367f, 0.2176f); // plane that flattens the face
    f = blend_sphere_pair(f, P, to_float3(0.1866f, 0.274f, -0.5157f), 0.08283f, 0.4182f, 0.1252f, 0.7553f, 0.1632f); // head front
    f = blend_sphere(f, P, to_float3(0, 0.2919f, -0.49f), 0.08861f, 0.2059f, 0.2794f); // nose middle
    f = blend_sphere(f, P, to_float3(0, -0.2878f, 0.4162f), 0.221f, 0.05f, 0.125f); // udder
    f = blend_sphere_pair(f, P, to_float3(0.2352f, -0.454f, 0.8239f), 0.01743f, 0.1009f, 0.18f, 0.8526f, 0.1563f); // back leg top
    f = blend_sphere(f, P, to_float3(0.2f * x_sign, -0.6063f, 0.791f), 0.1235f, 0.1626f, 0.22f); // back leg bottom
    f = blend_sphere_pair(f, P, to_float3(0.212f, -0.221f, 0.004702f), 0.003749f, 0.3448f, 0.29f, 0.6583f, 0.2142f); // front leg top
    f = blend_sphere_pair(f, P, to_float3(0.2792f, -0.4758f, -0.009692f), 0.07521f, 0.2497f, 0.29f, 0.3503f, 0.22f); // front leg mid
    f = blend_sphere(f, P, to_float3(0.2354f * x_sign, -0.5914f, 0.03336f), 0.1362f, 0.1222f, 0.22f); // front leg bottom
    f = blend_sphere_pair(f, P, to_float3(0.1695f, 0.8511f, -0.2575f), -0.02274f, 0.3244f, 0.29f, 0.2488f, 0.2932f); // horn bottom
    f = blend_sphere(f, P, to_float3(0.1819f * x_sign, 0.9089f, -0.2723f), 0.03964f, 0.1145f, 0.23f); // horn top

    // tail
    {
        float4 f2 = sdf_sphere(P, to_float3(0, 0.05389f, 0.8271f), 0.2886f);
        f2 = blend_sphere(f2, P, to_float3(0, -0.06683f, 1.023f), 0.02922f, 0.2081f, 0.1647f);
        f2 = blend_smax(f2, sdf_halfspace(P, to_float3(0, -0.8901f, -0.4557f), -0.3423f), 0.03333f, 0.23f);
        f2 = blend_smax(f2, sdf_halfspace(P, to_float3(0, 0.9783f, 0.2073f), 0.2804f), 0.4062f, 0.2252f);
        f = blend_smin_f4(f, f2, 0.03f, 0.1662f);
    }

    // ears
    {
        float4 f2 = sdf_xcylinder(P, to_float2(0.6402f, -0.246f), 0.1085f);
        f2 = blend_smax(f2, sdf_sphere(P, to_float3(0.242f * x_sign, 0.8241f, -0.133f), 0.2649f), 0.09f, 0.2078f);
        f = blend_smin_f4(f, f2, 0.1105f, 0.179f);
    }

    // add some roundness to the ears
    f = blend_sphere(f, P, to_float3(0.336f * x_sign, 0.6661f, -0.2359f), 0.01172f, 0.134f, 0.2554f);

    return f;
}

//#else // use optimized version of Spot signed distance function

// "SDF" function (bound) for the Spot approximation.
// Returns gradient in xyz and distance (lower bound) in w
// IMPORTANT: You need to normalize the gradient before using it as a normal vector.
__DEVICE__ float4 spot_sdf_and_gradient_Optimize(float3 P, float SPOT_SDF_OPTIMIZED_SCALE) {
    float x_sign = P.x < 0.0f ? -1.0f : 1.0f;

    float4 f = sphere_pair(P, to_float3(0.09054f, -0.06191f, 0.7222f), 0.1924f, 0.2536f, 0.2769f); // body rear
    f = blend_sphere_pair(f, P, to_float3(0.2373f, -0.3205f, 0.3429f), -0.00176f, 0.1056f, 0.4102f, 0.6691f, 0.2359f); // body mid lower
    f = blend_sphere_pair(f, P, to_float3(-0.05041f, 0.1178f, 0.1419f), 0.167f, 0.05f, 0.125f, 0.7952f, 0.1992f); // body mid upper

    if (P.y > -0.63f && P.y < 0.32f && P.z < 0.02f) {
        f = blend_sphere(f, P, to_float3(0, 0.00405f, 0.04695f), 0.1007f, 0.1422f, 0.59f); // chest
    }

    if (P.y > -0.34f && P.z < 0.59f) {
        f = blend_sphere(f, P, to_float3(0, 0.4546f, -0.2041f), 0.2553f, 0.1301f, 0.23f); // head mid
    }

    if (P.y > 0.13f && P.z < 0.05f) {
        f = blend_sphere_pair(f, P, to_float3(0.09402f, 0.651f, -0.408f), 0.1293f, 0.1836f, 0.23f, 0.15f, 0.22f); // head top front
    }

    if (P.y > 0.57f && P.z < 0.6f && P.z > -0.37f) {
        f = blend_sphere(f, P, to_float3(0, 0.7061f, -0.1507f), 0.01744f, 0.2003f, 0.2578f); // head top back
    }

    if (_fabs(P.x) < 0.41f && P.y > 0.20f && P.z < -0.33f) {
        // plane that flattens the face
        f = blend_smax(f, sdf_halfspace(P, to_float3(0, 0.1445f, -0.9895f), 0.5541f), 0.1367f, 0.2176f);
    }

    if (P.z < 0.6f) {
        f = blend_sphere_pair(f, P, to_float3(0.1866f, 0.274f, -0.5157f), 0.08283f, 0.4182f, 0.1252f, 0.7553f, 0.1632f); // head front
    }

    if (_fabs(P.x) < 0.28f && P.y > -0.31f && P.y < 0.61f && P.z < -0.24f) {
        f = blend_sphere(f, P, to_float3(0, 0.2919f, -0.49f), 0.08861f, 0.2059f, 0.2794f); // nose middle
    }

    if (_fabs(P.x) < 0.33f && P.y < -0.38f && P.z > -0.1f && P.z < 0.84f) {
        f = blend_sphere(f, P, to_float3(0, -0.2878f, 0.4162f), 0.221f, 0.05f, 0.125f); // udder
    }

    if (P.y < 0.8f && P.z > -0.16f) {
        f = blend_sphere_pair(f, P, to_float3(0.2352f, -0.454f, 0.8239f), 0.01743f, 0.1009f, 0.18f, 0.8526f, 0.1563f); // back leg top
    }

    if (P.y < -0.35f && P.z > 0.35f) {
        f = blend_sphere(f, P, to_float3(0.2f * x_sign, -0.6063f, 0.791f), 0.1235f, 0.1626f, 0.22f); // back leg bottom
    }

    if (P.y < 0.54f && P.z < 0.75f) {
        f = blend_sphere_pair(f, P, to_float3(0.212f, -0.221f, 0.004702f), 0.003749f, 0.3448f, 0.29f, 0.6583f, 0.2142f); // front leg top
    }

    if (P.y < -0.05f && P.z < 0.48f) {
        f = blend_sphere_pair(f, P, to_float3(0.2792f, -0.4758f, -0.009692f), 0.07521f, 0.2497f, 0.29f, 0.3503f, 0.22f); // front leg mid
    }

    if (P.y < -0.38f && P.z < 0.43f) {
        f = blend_sphere(f, P, to_float3(0.2354f * x_sign, -0.5914f, 0.03336f), 0.1362f, 0.1222f, 0.22f); // front leg bottom
    }

    if (P.y > 0.57f && P.z < 0.55f) {
        f = blend_sphere_pair(f, P, to_float3(0.1695f, 0.8511f, -0.2575f), -0.02274f, 0.3244f, 0.29f, 0.2488f, 0.2932f); // horn bottom
    }

    if (P.y > 0.71f && P.z < 0.25f) {
        f = blend_sphere(f, P, to_float3(0.1819f * x_sign, 0.9089f, -0.2723f), 0.03964f, 0.1145f, 0.23f); // horn top
    }

    // tail
    if (P.y > -0.28f && P.y < 0.55f && P.z > 0.85f) {
        float4 f2 = sdf_sphere(P, to_float3(0, 0.05389f, 0.8271f), 0.2886f);
        f2 = blend_sphere(f2, P, to_float3(0, -0.06683f, 1.023f), 0.02922f, 0.2081f, 0.1647f);
        f2 = blend_smax(f2, sdf_halfspace(P, to_float3(0, -0.8901f, -0.4557f), -0.3423f), 0.03333f, 0.23f);
        f2 = blend_smax(f2, sdf_halfspace(P, to_float3(0, 0.9783f, 0.2073f), 0.2804f), 0.4062f, 0.2252f);
        f = blend_smin_f4(f, f2, 0.03f, 0.1662f);
    }

    // ears
    if (P.y > 0.37f && P.z < 0.51f) {
        float4 f2 = sdf_xcylinder(P, to_float2(0.6402f, -0.246f), 0.1085f);
        f2 = blend_smax(f2, sdf_sphere(P, to_float3(0.242f * x_sign, 0.8241f, -0.133f), 0.2649f), 0.09f, 0.2078f);
        f = blend_smin_f4(f, f2, 0.1105f, 0.179f);

        if (_fabs(P.x) > 0.2f && P.z < 0.1f && P.z > -0.46f) {
            // add some roundness to the ears
            f = blend_sphere(f, P, to_float3(0.336f * x_sign, 0.6661f, -0.2359f), 0.01172f, 0.134f, 0.2554f);
        }
    }

    return SPOT_SDF_OPTIMIZED_SCALE * f;
}
//#endif // end of optimized version of Spot SDF


// "texture" function for getting the color index at a particular point on the surface
// If SPOT_TEXTURE_EDGE_GRADIENT is defined, this returns a signed distance and a gradient, and the returned index
//      is the color for the interior of the shape
// Otherwise, it returns the color index for the point

__DEVICE__ int spot_get_color_index(float3 P, bool NoSpots
#ifdef SPOT_TEXTURE_EDGE_GRADIENT
        , out float4 *f_grad
#endif
        ) {

#ifndef SPOT_TEXTURE_EDGE_GRADIENT
    float4 f_grad;
#endif

    *f_grad = to_float4(1, 1, 1, -1e20f);

    bool need_test_spots = false;

    if (P.y < -0.42f) { // udder and hooves
        if (P.y > -0.49f) { // udder
            // Using a simple ellipse here, because using the correct projected shape would require a
            //    closer fit for the 3D surface (and it isn't very visible)
            float2 q = swi2(P,x,z) - to_float2(0, 0.41f);

            (*f_grad).w = dot(q,q*to_float2(24,18)) - 1.0f;

#ifdef SPOT_TEXTURE_EDGE_GRADIENT
            swi3S(*f_grad,x,y,z, 2.0f*24.0f*q.x*to_float3(1,0,0) - 2.0f*18.0f*q.y*to_float3(0,0,1));
            return SPOT_COLOR_UDDER;
#else
            return (*f_grad).w < 0.0f ? SPOT_COLOR_UDDER : SPOT_COLOR_BASE;
#endif

        } else if (P.z < 0.2f || P.z > 0.625f) { // hooves
            if (P.y > -0.61f) {
                // Y coordinate of the edge is a function of angle
                // Equivalent to using circular harmonics, but expressed as polynomial in _sinf(angle) and _cosf(angle)

                float4 param1 = to_float4_s(0.0f), param2 = to_float4_s(0.0f);
                float3 param3  = to_float3_s(0.0f);
                float2 offset = to_float2_s(0.0f);

                if (P.z < 0.2f) {
                    offset = to_float2(0.241f, 0.031f);

                    if (P.x > 0.0f) { // front left
                        param1 = to_float4(-0.5329f, 0.00237f, 0.00374f, -0.0132f);
                        param2 = to_float4(-0.0189f, 0.0319f, 0.000537f, 0.00892f);
                        param3 = to_float3(0.0145f, -0.0247f, 0.00303f);
                    } else { // front right
                        param1 = to_float4(-0.5489f, 0.0064f, -0.00334f, 0.00312f);
                        param2 = to_float4(-0.0234f, -0.00934f, 0.0256f, 0.00612f);
                        param3 = to_float3(0.0252f, -0.00074f, -0.0294f);
                    }
                } else {
                    offset = to_float2(0.2014f, 0.7855f);

                    if (P.x > 0.0f) { // back left
                        param1 = to_float4(-0.5519f, -0.005f, -0.00348f, 0.000603f);
                        param2 = to_float4(0.0129f, -0.00268f, 0.00723f, 0.0105f);
                        param3 = to_float3(0.00688f, -0.00489f, -0.0136f);
                    } else { // back right
                        param1 = to_float4(-0.5499f, -0.0236f, -0.0044f, 0.0104f);
                        param2 = to_float4(-0.0051f,  0.0343f, 0.00274f, -0.0112f);
                        param3 = to_float3(0.0151f, -0.0178f, 0.00958f);
                    }
                }

                float2 q = to_float2(_fabs(P.x) - offset.x, offset.y - P.z);

                float s = 1.0f / length(q);

                float x = s*q.x, y = s*q.y;

                float A = param1.z + (param2.x + (param2.z + (param3.x + param3.z*x)*x)*x)*x; // factor out common expression

                (*f_grad).w = (P.y - param1.x - A*y - (param1.y + (param1.w + (param2.y + (param2.w + param3.y*x)*x)*x)*x)*x);

                float3 basis1 = to_float3(P.x < 0.0f ? -1.0f : 1.0f, 0.0f, 0.0f);
                const float3 basis2 = to_float3(0, 0, 1);

                float3 grad_d = s * (q.x*basis1 + q.y*basis2);
                float3 grad_s = -s*s * grad_d;

                float3 grad_x = q.x*grad_s + s*basis1;
                float3 grad_y = q.y*grad_s + s*basis2;

#ifdef SPOT_TEXTURE_EDGE_GRADIENT
                swi3S(*f_grad,x,y,z, (to_float3(0,1,0) - A*grad_y
                      - (y*(param2.x + (2.0f*param2.z + (3.0f*param3.x + 4.0f*param3.z*x)*x)*x)
                         + param1.y + (2.0f*param1.w + (3.0f*param2.y + (4.0f*param2.w + 5.0f*param3.y*x)*x)*x)*x)*grad_x));

                return SPOT_COLOR_HOOVES;
#else
                return (*f_grad).w < 0.0f ? SPOT_COLOR_HOOVES : SPOT_COLOR_BASE;
#endif
            } else {
                return SPOT_COLOR_HOOVES;
            }
        } else {
            return SPOT_COLOR_UDDER;
        }
    } else if (P.z > -0.175f) {
        need_test_spots = true;
    } else if (P.y > 0.09f) { // head area
        float k = P.y + P.z;

        if (k < -0.055f) { // nose area
            if (k < -0.2f) { // safe nose area
                if (P.z < -0.62f) { // test if point is inside nostril shape
                    // Use the same SDF-like code as is used for the spots, to reduce code size
                    //      (even though it's overkill for these shapes)
                    need_test_spots = true;
                } else {
                    return SPOT_COLOR_NOSE;
                }
            } else { // test edge of nose
                // Rotate coordinate to new basis, then distance along one of the axes is a
                //      function of angle around that axis
                // Equivalent to using circular harmonics, but expressed as polynomial in _sinf(angle) and _cosf(angle)

                const float3 basis1 = to_float3(1, 0, 0);
                const float3 basis2 = to_float3(0, -0.7805f, 0.6251f);
                const float3 basis3 = to_float3(0, 0.6251f, 0.7805f);

                float2 q0 = to_float2(dot(P, basis1), dot(P, basis2) + 0.5194f);

                float d = length(q0);
                float s = 1.0f / d;

                float y = s * q0.y;

                (*f_grad).w = 0.1213f + dot(P, basis3) + y*(-0.0372f + y*(0.09249f
                        + y*(0.1033f + y*(-0.007562f + y*(-0.1298f + y*(-0.217f + y*(0.07828f + y* 0.1697f)))))));

                float3 grad_d = s * (q0.x*basis1 + q0.y*basis2);
                float3 grad_s = -s*s * grad_d;
                float3 grad_y = q0.y*grad_s + s*basis2;

#ifdef SPOT_TEXTURE_EDGE_GRADIENT
                swi3S(*f_grad,x,y,z, (basis3 + (-0.0372f + (2.0f*0.09249f + (3.0f*0.1033f + (-4.0f*0.007562f
                        + (-5.0f*0.1298f + (-6.0f*0.217f + (7.0f*0.07828f + 8.0f*0.1697f*y)*y)*y)*y)*y)*y)*y)*grad_y));

                return SPOT_COLOR_NOSE;
#else
                return (*f_grad).w < 0.0f ? SPOT_COLOR_NOSE : SPOT_COLOR_BASE;
#endif
            }
        } else {
            if (k < 0.27f) {
                // Eyes and eye highlights are ellipses projected onto surface
                // Using arbitrary direction vectors for the major and minor axes of the ellipses.
                // (i.e. the shape is the intersection of an arbitrary elliptical cylinder and the surface)
                float3 coeff1, coeff2;
                float2 offset;

                if (P.x > 0.0f) {
                    coeff1 = to_float3(0.506f, -9.169f, -3.82f);
                    coeff2 = to_float3(22.4f, 0.82f, 1.003f);
                    offset = to_float2(3.712f, -2.104f);
                } else {
                    coeff1 = to_float3(-0.662f, -9.22f, -3.813f);
                    coeff2 = to_float3(22.8f, -0.939f, -1.684f);
                    offset = to_float2(3.7407f, 2.217f);
                }

                float2 q = to_float2(dot(P, coeff1), dot(P, coeff2)) + offset;

                (*f_grad).w = dot(q, q) - 1.0f;

#ifdef SPOT_TEXTURE_EDGE_GRADIENT
                swi3S(*f_grad,x,y,z, 2.0f*(q.x*coeff1 + q.y*coeff2));

                // (eye highlight is tested by a separate function)

                return SPOT_COLOR_EYES;
#else

                if ((*f_grad).w > 0.0f) {
                    return SPOT_COLOR_BASE;
                } else {
                    // Test if point is inside eye highlight (another ellipse)

                    if (P.x > 0.0f) {
                        coeff1 = to_float3(1.922f, -27.251f, -10.984f);
                        coeff2 = to_float3(64.291f, 2.989f, 3.835f);
                        offset = to_float2(12.3613f, -6.992f);
                    } else {
                        coeff1 = to_float3(-1.73f, -27.289f, -10.995f);
                        coeff2 = to_float3(63.893f, -3.172f, -2.179f);
                        offset = to_float2(12.3966f,  6.8743f);
                    }

                    q = to_float2(dot(P, coeff1), dot(P, coeff2)) + offset;

                    return dot(q, q) < 1.0f ? SPOT_COLOR_EYE_HIGHLIGHT : SPOT_COLOR_EYES;
                }
#endif

            } else if (k < 0.431f) { // shapes for underside of the ears
                // Use the same SDF-like code as is used for the spots
                need_test_spots = true;
            } else { // horns
                float3 bound_low = to_float3(0.07f, 0.76f, -0.34f);
                float3 bound_high = to_float3(0.23f, 1.27f, -0.21f);

                if (_fabs(P.x) > bound_low.x && _fabs(P.x) < bound_high.x && P.y > bound_low.y && P.y < bound_high.y && P.z > bound_low.z && P.z < bound_high.z) {
                    // Rotate coordinate to new basis, then distance along one of the axes is a
                    //      function of angle around that axis
                    // Equivalent to using circular harmonics, but expressed as polynomial in _sinf(angle) and _cosf(angle)

                    float4 param1;
                    float3 param2;

                    if (P.x > 0.0f) { // left
                        param1 = to_float4(0.81487859f, -0.00204274f, -0.0014182f, 0.00378644f);
                        param2 = to_float3(-0.00747133f, 0.00363717f, 0.00332907f);
                    } else { // right
                        param1 = to_float4(8.14601653e-01, -3.32745045e-03, -2.74123036e-04, 4.47013305e-03);
                        param2 = to_float3(-8.06562515e-03, 3.30476957e-03, 3.64574427e-03);
                    }

                    float3 basis1 = to_float3(P.x < 0.0f ? 0.01294f : -0.01294f, -0.03464f, -0.9993f);
                    float3 basis2 = to_float3(P.x < 0.0f ? -0.9368f : 0.9368f, -0.3499f, 0.0f);
                    float3 basis3 = to_float3(P.x < 0.0f ? -0.3496f : 0.3496f, 0.9362f, -0.03697f);

                    float3 q0 = to_float3(dot(basis1, P) - 0.244f, dot(basis2, P) + 0.14715f, dot(basis3, P));

                    float s = 1.0f / length(swi2(q0,x,y));

                    float x = s*q0.x, y = s*q0.y;

                    float A = param1.z + (param2.x + param2.z*x)*x; // factor out shared expression

                    (*f_grad).w = param1.x + (param1.y + (param1.w + param2.y*x)*x)*x + y*A - q0.z;

                    // Removing brackets around s*s*s causes shader compilation time to jump by 8 or 9 seconds
                    //      in WebGL on Windows (presumably due to a quirk in the fxc compiler)
                    // Thanks to @Nguyen2007 on Shadertoy for suggesting I try the brackets!
                    float3 grad_s = -(s*s*s)*(q0.x*basis1 + q0.y*basis2);

                    float3 grad_x = q0.x*grad_s + s*basis1;
                    float3 grad_y = q0.y*grad_s + s*basis2;

#ifdef SPOT_TEXTURE_EDGE_GRADIENT
                    swi3S(*f_grad,x,y,z, ((param1.y + (2.0f*param1.w + 3.0f*param2.y*x)*x) * grad_x
                                + grad_y*A
                                + grad_x*y*(param2.x + 2.0f*param2.z*x)
                                - basis3));

                    return SPOT_COLOR_HORNS;
#else
                    return (*f_grad).w < 0.0f ? SPOT_COLOR_HORNS : SPOT_COLOR_BASE;
#endif
                }
            }
        }
    }

    if ( ! need_test_spots) {
        return SPOT_COLOR_BASE;
    } else {
        int spotnum = 0;

        if (P.z < -0.175f) { // ears or nostrils
            if (P.z < -0.5f) { // nostrils
                if (P.x > 0.0f) {
                    spotnum = 11; // left side
                } else {
                    spotnum = 12; // right side
                }
            } else { // shapes for underside of ears
                if (P.x > 0.0f) {
                    spotnum = 9; // left side
                } else {
                    spotnum = 10; // right side
                }
            }
        } else if (P.y + 0.5f*P.x > 0.51f) { // spot on back of head (spot10)
            spotnum = 13;
        } else if (P.x > 0.04f) { // left side
            if (P.z < 0.42f) { // large spot on left side at front (spot1)
                spotnum = 14;
            } else { // four smaller spots
                if (P.y < -0.01f) { // lower spots
                    if (P.z < 0.75f) { // small spot on left side, lower down (spot9)
                        spotnum = 1;
                    } else { // medium-sized spot above left leg, at back (spot8)
                        spotnum = 2;
                    }
                } else { // upper spots
                    if (P.z < 0.625f) { // small spot on top of back, left side (spot7)
                        spotnum = 3;
                    } else { // medium-sized spot on rump, left side (spot2)
                        spotnum = 4;
                    }
                }
            }
        } else { // right side
            if (P.z < 0.15f) {
                if (P.y > 0.22f) { // spot on back of head, lower down (spot11)
                    spotnum = 5;
                } else { // small spot on right side at front (spot4)
                    spotnum = 6;
                }
            } else {
                if (P.z < 0.72f) {
                    // (The P.y > 0.225f cutoff is a bit iffy - may break if the surface gets distorted slightly)
                    if (P.y > 0.225f) { // small spot on top near front, right side (spot5)
                        spotnum = 7;
                    } else { // large spot on right side (spot3)
                        spotnum = 15;
                    }
                } else { // medium sized spot on rump, right side (spot6)
                    spotnum = 8;
                }
            }
        }

        float3 planeN  = to_float3_s(0.0f); // normal for plane that we're projecting onto
        float4 coeff1  = to_float4_s(0.0f), coeff2 = to_float4_s(0.0f); // coefficients for two ellipses
        float2 center1 = to_float2_s(0.0f), center2 = to_float2_s(0.0f), mix1 = to_float2_s(0.0f); // centers for two ellipses, and blending parameters

        switch (spotnum) {
        case 1: // small spot on left side, lower down (spot9)
            planeN = to_float3(0.98218f, 0.18135f, 0.04944f);
            center1 = to_float2(-0.5091f, -0.1256f);
            coeff1 = to_float4(0.1366f, -0.0554f, 0.2765f, 0);
            center2 = to_float2(-0.6079f, -0.1809f);
            coeff2 = to_float4(0.1101f, 0.0782f, 0.1274f, 0.000392f);
            mix1 = to_float2(0.1385f, 0.23f);
            break;
        case 2: // medium-sized spot above left leg, at back (spot8)
            planeN = to_float3(0.49251f, -0.02653f, 0.8699f);
            center1 = to_float2(-0.2795f, -0.2912f);
            coeff1 = to_float4(0.1927f, 0.0549f, 0.2137f, 0.0132f);
            center2 = to_float2(-0.2137f, -0.1526f);
            coeff2 = to_float4(0.0166f, 0.0376f, 0.135f, 0);
            mix1 = to_float2(0.1597f, 0.23f);
            break;
        case 3: // small spot on top of back, left side (spot7)
            planeN = to_float3(0.34075f, 0.92455f, 0.1706f);
            center1 = to_float2(-0.4377f, -0.021f);
            coeff1 = to_float4(0.1177f, 0.0134f, 0.0717f, 0.00951f);
            center2 = to_float2(-0.5001f, -0.0418f);
            coeff2 = to_float4(0.1044f, 0.00905f, 0.0619f, 0.00893f);
            mix1 = to_float2(0.031f, 0.1399f);
            break;
        case 4: // medium-sized spot on rump, left side (spot2)
            planeN = to_float3(0.58299f, 0.67175f, 0.45702f);
            center1 = to_float2(-0.6881f, -0.0719f);
            coeff1 = to_float4(0.1068f, -0.00287f, 0.0939f, 0.0304f);
            center2 = to_float2(-0.5679f, -0.0973f);
            coeff2 = to_float4(0.177f, 0.0107f, 0.1122f, 0.0362f);
            mix1 = to_float2(0.0272f, 0.23f);
            break;
        case 5: // spot on back of head, lower down (spot11)
            planeN = to_float3(-0.34182f, -0.02999f, 0.93929f);
            center1 = to_float2(-0.0333f, -0.4003f);
            coeff1 = to_float4(0.1088f, -0.00894f, 0.0596f, 0);
            center2 = to_float2(0.1086f, -0.431f);
            coeff2 = to_float4(0.0636f, -0.0315f, 0.0875f, 0.00565f);
            mix1 = to_float2(0.1062f, 0.23f);
            break;
        case 6: // small spot on right side at front (spot4)
            planeN = to_float3(-0.79750f, 0.34981f, -0.49156f);
            center1 = to_float2(-0.1655f, 0.1492f);
            coeff1 = to_float4(0.1504f, -0.0393f, 0.1478f, 0.00295f);
            center2 = to_float2(-0.0621f, 0.0698f);
            coeff2 = to_float4(0.0846f, -0.0602f, 0.0765f, 0.00239f);
            mix1 = to_float2(0.1216f, 0.23f);
            break;
        case 7: // small spot on top near front, right side (spot5)
            planeN = to_float3(-0.18690f, 0.91381f, 0.36059f);
            center1 = to_float2(-0.2437f, 0.0116f);
            coeff1 = to_float4(0.1528f, -0.0222f, 0.1654f, 0.0117f);
            center2 = to_float2(-0.3009f, 0.0382f);
            coeff2 = to_float4(0.1839f, 0.0582f, 0.1253f, 0.00967f);
            mix1 = to_float2(0.0174f, 0.23f);
            break;
        case 8: // medium sized spot on rump, right side (spot6)
            planeN = to_float3(-0.48805f, 0.7036f, 0.51649f);
            center1 = to_float2(-0.5997f, 0.1152f);
            coeff1 = to_float4(0.0874f, 0.0317f, 0.1675f, 0.0174f);
            center2 = to_float2(-0.6598f, 0.0174f);
            coeff2 = to_float4(0.0295f, 0.0411f, 0.1506f, 0);
            mix1 = to_float2(0.0783f, 0.23f);
            break;
        case 9: // left ear
            planeN = to_float3(0.40919f, -0.76636f, -0.49523f);
            center1 = to_float2(0.3761f, 0.5658f);
            coeff1 = to_float4(0.0511f, -0.0299f, 0.0297f, 0);
            center2 = to_float2(0.4791f, 0.5732f);
            coeff2 = to_float4(0.0414f, 0.0223f, 0.0595f, 0);
            mix1 = to_float2(0.0574f, 0.28f);
            break;
        case 10: // right ear
            planeN = to_float3(-0.40919f, -0.76636f, -0.49523f);
            center1 = to_float2(0.4539f, -0.6041f);
            coeff1 = to_float4(0.0624f, -0.0443f, 0.0659f, 0.00144f);
            center2 = to_float2(0.372f, -0.5548f);
            coeff2 = to_float4(0.1054f, 0.0375f, 0.1181f, 0);
            mix1 = to_float2(0.0815f, 0.2735f);
            break;
        case 11: // left nostril
            planeN = to_float3(0.12487f, 0.19492f, -0.97284f);
            center1 = to_float2(-0.1959f, 0.0567f);
            coeff1 = to_float4(0.0891f, -0.00184f, 0.0739f, 0.00699f);
            center2 = to_float2(-0.2156f, 0.0443f);
            coeff2 = to_float4(0.0574f, 0.00654f, 0.0429f, 0.00594f);
            mix1 = to_float2(0.0145f, 0.2265f);
            break;
        case 12: // right nostril
            planeN = to_float3(0.12487f, -0.19492f, 0.97284f);
            center1 = to_float2(-0.2199f, 0.0413f);
            coeff1 = to_float4(0.0908f, 0.0152f, 0.0779f, 0.00808f);
            center2 = to_float2(-0.2005f, 0.0534f);
            coeff2 = to_float4(0.1348f, 0.00514f, 0.1301f, 0.00916f);
            mix1 = to_float2(0.0169f, 0.2296f);
            break;
        case 13: // spot on back of head (spot10)
            planeN = to_float3(0.13503f, 0.54333f, 0.82859f);
            center1 = to_float2(0.5555f, 0.2104f);
            coeff1 = to_float4(0.00243f, 0.000921f, 0.00377f, 0);
            center2 = to_float2(0.4877f, 0.0684f);
            coeff2 = to_float4(0.1182f, 0.0541f, 0.1076f, 0.0126f);
            mix1 = to_float2(0.01f, 0.1618f);
            break;
        case 14: // large spot on left side at front (spot1)
            planeN = to_float3(0.88268f, 0.42832f, -0.19346f);
            center1 = to_float2(-0.1894f, 0.1312f);
            coeff1 = to_float4(0.3596f, -0.0157f, 0.4675f, 0.0626f);
            center2 = to_float2(-0.0924f, -0.1426f);
            coeff2 = to_float4(0.1051f, -0.00376f, 0.1909f, 0.0394f);
            mix1 = to_float2(0.0511f, 0.2459f);
            break;
        case 15: // large spot on right side (spot3)
            planeN = to_float3(-0.92778f, 0.36424f, 0.08099f);
            center1 = to_float2(-0.322f, 0.2731f);
            coeff1 = to_float4(0.5084f, 0.0655f, 0.567f, 0.0364f);
            center2 = to_float2(-0.3653f, -0.0556f);
            coeff2 = to_float4(0.2083f, 0.0297f, 0.1228f, 0.0205f);
            mix1 = to_float2(0.0665f, 0.3003f);
            break;
        }

        /*
            Construct a tangent basis from the given normal vector and project P into that basis.
            Simplification of this (assuming planeN is normalized):
                T = -normalize(to_float3(0,0,1) - planeN.z*planeN); // orthonormalization of (0,0,-1) and planeN
                B = cross(planeN, T);

            putting T and B in a matrix for convenience
        */
        mat3 M = mul_mat3_f(transpose(to_mat3_f3(planeN.z*planeN - to_float3(0,0,1), to_float3(-planeN.y, planeN.x, 0), to_float3_s(0.0f))) , 1.0f/_sqrtf(1.0f - planeN.z*planeN.z));

        float2 q = swi2(mul_mat3_f3(M , P),x,y);

        float3 f_pd = blend_smin(ellipse_function(q - center1, swi3(coeff1,x,y,z), coeff1.w),
                                 ellipse_function(q - center2, swi3(coeff2,x,y,z), coeff2.w), mix1.x, mix1.y);


        // Blend with more ellipses if needed
        if (spotnum >= 13) {
            if (spotnum == 13) { // spot on back of head (spot10)
                center1 = to_float2(0.4555f, 0.071f);
                coeff1  = to_float4(0.036f, -0.00225f, 0.0288f, 0.00132f);
                mix1    = to_float2(0.0657f, 0.1502f);
            } else if (spotnum == 14) { // large spot on left side at front (spot1)
                center1 = to_float2(-0.2102f, -0.00911f);
                coeff1  = to_float4(0.0108f, 0.0135f, 0.0224f, 0);
                mix1    = to_float2(0.0866f, 0.2428f);
            } else if (spotnum == 15) { // large spot on right side (spot3)
                center1 = to_float2(-0.2824f, 0.0226f);
                coeff1  = to_float4(0.1228f, 0.072f, 0.1511f, 0.0216f);
                mix1    = to_float2(0.0583f, 0.2272f);
            }

            float3 f_pd2 = ellipse_function(q - center1, swi3(coeff1,x,y,z), coeff1.w);

            if (spotnum >= 14) {
                float2 mix2;

                if (spotnum == 14) { // large spot on left side at front (spot1)
                    center1 = to_float2(-0.3441f, -0.2393f);
                    coeff1  = to_float4(0.0392f, 0.0036f, 0.0383f, 0.0153f);
                    mix2    = to_float2(0.0315f, 0.125f);
                } else if (spotnum == 15) { // large spot on right side (spot3)
                    center1 = to_float2(-0.4797f, 0.1786f);
                    coeff1  = to_float4(0.1872f, 0.0276f, 0.5069f, 0.0762f);
                    mix2    = to_float2(0.0651f, 0.2821f);
                }

                float3 f = ellipse_function(q - center1, swi3(coeff1,x,y,z), coeff1.w);

                f_pd2 = blend_smin(f_pd2, f, mix2.x, mix2.y);
            }

            f_pd = blend_smin(f_pd, f_pd2, mix1.x, mix1.y);
        }

#ifdef SPOT_TEXTURE_EDGE_GRADIENT

        //f_grad = to_float4(swi2(swi2(f_pd,x,y) * M, f_pd.z); //??????????????????
//        *f_grad = to_float4_f2f2(swi2(mul_f3_mat3(f_pd , M),x,y), to_float2(f_pd.z, 1.0f) );

          *f_grad = to_float4_aw(mul_f3_mat3(f_pd , M), f_pd.z );
#else
        if (f_pd.z > 0.0f) { // point is not inside shape
            return spotnum == 11 || spotnum == 12 ? SPOT_COLOR_NOSE : SPOT_COLOR_BASE;
        }
#endif

        return spotnum == 9 || spotnum == 10 ? SPOT_COLOR_EARS : spotnum == 11 || spotnum == 12 ? SPOT_COLOR_NOSTRILS : NoSpots ? SPOT_COLOR_BASE : SPOT_COLOR_SPOTS;
    }
}

#ifdef SPOT_TEXTURE_EDGE_GRADIENT

// Separate function for testing high highlight shape, so it can be antialiased when edge is close to eye edge
__DEVICE__ float4 spot_get_eye_highlight_grad(float3 P) {
    float3 coeff1 = to_float3_s(0.0f), coeff2 = to_float3_s(0.0f);
    float2 offset = to_float2_s(0.0f);

    if (P.x > 0.0f) {
        coeff1 = to_float3(1.922f, -27.251f, -10.984f);
        coeff2 = to_float3(64.291f, 2.989f, 3.835f);
        offset = to_float2(12.3613f, -6.992f);
    } else {
        coeff1 = to_float3(-1.73f, -27.289f, -10.995f);
        coeff2 = to_float3(63.893f, -3.172f, -2.179f);
        offset = to_float2(12.3966f,  6.8743f);
    }

    float2 q = to_float2(dot(P, coeff1), dot(P, coeff2)) + offset;

    return to_float4_aw(2.0f*(q.x*coeff1 + q.y*coeff2), dot(q, q) - 1.0f);
}

#endif

