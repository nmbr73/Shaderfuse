/*
    See Common for the shape approximation functions and related definitions.

    This file contains the raymarching and rendering demo code only.

*/


// Uncomment one of these lines:
//#define ray_march ray_march_simple
#define ray_march ray_march_bisect

// ray_march_simple may need many sphere tracing steps to remove visible artifacts near edges
//const int RAY_MARCH_SIMPLE_MAX_ITERATIONS = 500;
#define RAY_MARCH_SIMPLE_MAX_ITERATIONS  500

// ray_march_bisect uses fewer iterations, but may step past some surface intersections near edges
//   causing apparent shape to shrink slightly (depending on value of RAY_MARCH_BISECT_MIN_STEP).
//const int RAY_MARCH_BISECT_MAX_ITERATIONS = 100;
#define RAY_MARCH_BISECT_MAX_ITERATIONS  100

// For simple ray marcher: stop ray marching if absolute value is less than this
//const float RAY_MARCH_SIMPLE_SDF_THRESHOLD = 0.0001f;
#define RAY_MARCH_SIMPLE_SDF_THRESHOLD  0.0001f

// For simple ray marcher: if absolute value is less than this when iteration max is reached, treat as an intersection
//const float RAY_MARCH_SIMPLE_SDF_THRESHOLD2 = 0.001f;
#define RAY_MARCH_SIMPLE_SDF_THRESHOLD2 0.001f

// For bisecting ray marcher: stop ray marching if absolute value is less than this (during initial phase before bisection)
//const float RAY_MARCH_BISECT_SDF_THRESHOLD = 0.00005f;
#define RAY_MARCH_BISECT_SDF_THRESHOLD  0.00005f

// For bisecting ray marcher: stop bisecting if difference between upper and lower distance bounds is less than this
//const float RAY_MARCH_BISECT_DISTANCE_THRESHOLD = 0.00002f;
#define RAY_MARCH_BISECT_DISTANCE_THRESHOLD  0.00002f

// For bisecting ray marcher: minimum step size when not yet bisecting
// (larger value may cause it to skip over fine details or edges)
//const float RAY_MARCH_BISECT_MIN_STEP = 0.01f;
#define RAY_MARCH_BISECT_MIN_STEP  0.01f

// For bisecting ray marcher: take this many steps before applying RAY_MARCH_BISECT_MIN_STEP
//const int RAY_MARCH_BISECT_INITIAL_STEP_COUNT = 8;
#define RAY_MARCH_BISECT_INITIAL_STEP_COUNT  8

// Define this to scale up the step size in increments after RAY_MARCH_BISECT_INITIAL_STEP_COUNT reached
// May be slightly slower, but gives more precise outline for nearest edge
//  (will not help for later edges, if ray passes close to multiple edges)
#define RAY_MARCH_BISECT_RAMP_UP_STEP

// Multiplier to use if RAY_MARCH_BISECT_RAMP_UP_STEP is defined
//const float RAY_MARCH_BISECT_RAMP_UP_MULT = 1.25f;
#define RAY_MARCH_BISECT_RAMP_UP_MULT  1.25f



// Set this to non-zero to show the approximate number of iterations used for each pixel
//     red: 100 iterations or more
//     yellow: 50 iterations or more
//     green: 20 iterations or more
//     cyan: 10 iterations or more
//     blue: 5 iterations or more
//     cow color: fewer than 5 iterations
//#define SHOW_ITERATION_COUNT 0

// If set to false, the model will initially be revolving, but will stop as soon as you click on the image.
// If set to true, you will not be able to rotate manually.
//const bool FORCE_TURNTABLE_MODE = false;
//
//const float TURNTABLE_SPEED1  = 1.0f/5.0f; // rotation speed
//const float TURNTABLE_SPEED2  = 1.0f/15.0f; // speed of oscillation in secondary direction
//const float TURNTABLE_DEPTH   = 0.3f; // how much the angle changes in the secondary direction
//
//const float CAMERA_SHIFT_Y    = 0.0f;
//const float CAMERA_Z_DISTANCE = 4.5f;
//const float VIEW_ANGLE_FACTOR = 2.0f;
//
//const float3 BACKGROUND_COLOR = {0.1f, 0.1f, 0.2f};

// NOTE: If SPOT_TEXTURE_EDGE_GRADIENT is defined (in Common), the edges of the shapes in the texture will be antialiased

#define PI  3.14159265f


// AABB intersection implementation
__DEVICE__ float2 vec2_sort(float2 v) {
    return to_float2(_fminf(v.x, v.y), _fmaxf(v.x, v.y));
}

__DEVICE__ float2 slab_nearfar(float a, float b, float rV) {
    return vec2_sort(rV * to_float2(a, b));
}

__DEVICE__ float2 intersect_box(float3 P1, float3 P2, float3 rV, float3 ray_O) {
    P1 -= ray_O;
    P2 -= ray_O;

    float2 tx = slab_nearfar(P1.x, P2.x, rV.x);
    float2 ty = slab_nearfar(P1.y, P2.y, rV.y);
    float2 tz = slab_nearfar(P1.z, P2.z, rV.z);

    return to_float2(_fmaxf(tx.x, _fmaxf(ty.x, tz.x)), _fminf(tx.y, _fminf(ty.y, tz.y)));
}

__DEVICE__ float2 spot_ray_bound_intersection(float3 ray_O, float3 V) {
    const float3 SPOT_BOUNDING_BOX_LOW  = to_float3(-0.458f, -0.73f, -0.664f);
    const float3 SPOT_BOUNDING_BOX_HIGH = to_float3(0.458f, 0.95f,  1.047f);
    return intersect_box(SPOT_BOUNDING_BOX_LOW, SPOT_BOUNDING_BOX_HIGH, 1.0f/V, ray_O);
}

// Simple sphere tracing ray marcher
__DEVICE__ float ray_march_simple(float3 ray_O, float3 V, out int *itr_count, bool SPOT_SDF_OPTIMIZED, float SPOT_SDF_OPTIMIZED_SCALE) {
    float t=0.0f, t_max=0.0f;

    {
        float2 nearfar = spot_ray_bound_intersection(ray_O, V);

        t = _fmaxf(nearfar.x, 0.0f);
        t_max = nearfar.y;

        if (t >= t_max) {
            *itr_count = 0;
            return 1e20f;
        }
    }

    // "_fminf(0, iFrame)" is just to prevent loop unrolling by the compiler
    int itr_max = 0 + RAY_MARCH_SIMPLE_MAX_ITERATIONS;

    for (int itr=0; itr < itr_max; itr++) {
        if (t > t_max) {
            *itr_count = itr;
            return 1e20f;
        }

        float d = SPOT_SDF_OPTIMIZED ? spot_sdf_and_gradient_Optimize(ray_O + t*V, SPOT_SDF_OPTIMIZED_SCALE).w : spot_sdf_and_gradient(ray_O + t*V).w;

        if (d < RAY_MARCH_SIMPLE_SDF_THRESHOLD || (d < RAY_MARCH_SIMPLE_SDF_THRESHOLD2 && itr == itr_max - 1)) {
            *itr_count = itr;
            return t;
        }
        t += d;
    }

    *itr_count = itr_max;

    return 1e20f;
}

// Ray marcher that overshoots and then uses bisection to find intersection
__DEVICE__ float ray_march_bisect(float3 ray_O, float3 V, out int *itr_count, bool SPOT_SDF_OPTIMIZED, float SPOT_SDF_OPTIMIZED_SCALE) {
    float t = 0.0f, t_max = 0.0f;

    {
        float2 nearfar = spot_ray_bound_intersection(ray_O, V);

        t = _fmaxf(nearfar.x, 0.0f);
        t_max = nearfar.y;

        if (t >= t_max) {
            *itr_count = 0;
            return 1e20f;
        }
    }

    float t_bound_near = 0.0f;
    float t_bound_far = 1e20f;

    float f_near = 1e20f;
    float f_far = -1e20f;

#ifdef RAY_MARCH_BISECT_RAMP_UP_STEP
    float step_multipler = RAY_MARCH_BISECT_RAMP_UP_MULT;
#endif

    // "_fminf(0, iFrame)" is just to prevent loop unrolling by the compiler
    int itr_max = 0 + RAY_MARCH_BISECT_MAX_ITERATIONS;

    for (int itr=0; itr < itr_max; itr++) {
        float d = SPOT_SDF_OPTIMIZED ? spot_sdf_and_gradient_Optimize(ray_O + t*V, SPOT_SDF_OPTIMIZED_SCALE).w : spot_sdf_and_gradient(ray_O + t*V).w;

        if (d > 0.0f) {
            t_bound_near = t + d;
            f_near = d;
        } else {
            t_bound_far = t + d;
            f_far = d;
        }

        if (t_bound_far > 1e18f) {
            if (_fabs(d) < RAY_MARCH_BISECT_SDF_THRESHOLD) {
                *itr_count = itr;
                return t;
            }

            if (itr > RAY_MARCH_BISECT_INITIAL_STEP_COUNT) {

#ifndef RAY_MARCH_BISECT_RAMP_UP_STEP
                d = _fmaxf(d, RAY_MARCH_BISECT_MIN_STEP);
#else
                d = _fmaxf(d,  _fminf(d*step_multipler, RAY_MARCH_BISECT_MIN_STEP));
                step_multipler *= RAY_MARCH_BISECT_RAMP_UP_MULT;
#endif
            }

            t += d;

            if (t > t_max) {
                *itr_count = itr;
                return 1e20f;
            }
        } else {
            t = 0.5f*(t_bound_near + t_bound_far);

            if (t_bound_far - t_bound_near < RAY_MARCH_BISECT_DISTANCE_THRESHOLD

                    // Not necessary, but seems to help:
                    || (f_near - f_far) < RAY_MARCH_BISECT_DISTANCE_THRESHOLD

                    ) {
                *itr_count = itr;
                return t;
            }
        }
    }

    *itr_count = itr_max;

    if (t_bound_far < 1e18f) {
        return t = 0.5f*(t_bound_near + t_bound_far);
    } else {
        return 1e20f;
    }
}

// Note: this is a direct translation of the sRGB definition into branch-less GLSL (other people's code likely looks similar)
__DEVICE__ float3 linear_to_srgb(float3 C) {
    return mix_f3(12.92f*C, 1.055f*pow_f3(C, to_float3_s(1.0f/2.4f)) - 0.055f, step(to_float3_s(0.0031308f), C));
}

__DEVICE__ float rgb_to_luminance(float3 c) {
    return dot(c, to_float3(0.2126f, 0.7152f, 0.0722f));
}

// Clip linear RGB colors, trying to preserve brightness and color
// (not sure if this counts as "tone mapping")
__DEVICE__ float3 gamut_clip(float3 rgb) {
    float target_luminance = clamp(rgb_to_luminance(rgb), 0.0f, 1.0f);

    rgb = _fmaxf(rgb, to_float3_s(0));

    rgb /= _fmaxf(_fmaxf(_fmaxf(rgb.x, rgb.y), rgb.z), 1e-12f);

    float L = _fminf(rgb_to_luminance(rgb), 0.9999f);

    float a = target_luminance <= L ? target_luminance / L : (1.0f - target_luminance) / (1.0f - L);

    return a*rgb + (target_luminance - a*L);
}

__DEVICE__ mat3 make_camera_rotation_matrix(float4 mouse4, float2 resolution, float iTime, bool FORCE_TURNTABLE_MODE, float TURNTABLE_SPEED1, float TURNTABLE_SPEED2, float TURNTABLE_DEPTH) {
    float xz=0.0f, yz=0.0f;

    if (FORCE_TURNTABLE_MODE || dot(abs_f4(mouse4), to_float4_s(1)) == 0.0f) {
        xz = PI * 2.0f * fract(TURNTABLE_SPEED1 * iTime);
        yz = -0.5f*PI * TURNTABLE_DEPTH * _sinf(PI * 2.0f * fract(TURNTABLE_SPEED2 * iTime));
    } else {
        float2 m = 2.0f * (swi2(mouse4,x,y) / resolution - 0.5f);

        xz = PI * m.x + PI;
        yz = 0.5f*PI * clamp(m.y, -0.999f, 0.999f);
    }

    float sin_xz = _sinf(xz);
    float cos_xz = _cosf(xz);
    float cos_yz = _cosf(yz);
    float sin_yz = _sinf(yz);

    // (normalize is for precision loss only)
    return to_mat3_f3(
                      normalize(to_float3(cos_xz, 0, -sin_xz)),
                      normalize(to_float3(-sin_yz*sin_xz, cos_yz, -sin_yz*cos_xz)),
                      normalize(to_float3(sin_xz*cos_yz, sin_yz, cos_xz*cos_yz)));
}


// Daylight lighting approximation for Lambertian surfaces
// Loosely based on the "Autumn Park" HDRI environment map from Poly Haven
__DEVICE__ float3 lighting_approx(float3 N) {

    // sun should really be 34 degrees above horizon for this lighting approximation to make sense
    float3 LIGHT_DIR = normalize(to_float3(_cosf(PI/180.0f*34.0f)*_cosf(PI/4.0f), _sinf(PI/180.0f*34.0f), _cosf(PI/180.0f*34.0f)*_sinf(PI/4.0f)));


    float d = dot(N, LIGHT_DIR);

    float3 c;

    c.z = 0.5013f + (0.288f - 0.1489f*N.y)*N.y + (0.1818f + 0.1376f*d)*d;
    c.y = -0.1509f + 0.8631f*c.z + (0.02822f*N.y - 0.1239f)*N.y;
    c.x = -0.3396f*c.z + 1.0746f*c.y;

    return c + _fmaxf(d, 0.0f) * to_float3(1.968f, 1.889f, 1.523f);
}

__DEVICE__ mat3 projection_Jacobian(float x, float y, float image_z) {
    float s = 1.0f / _sqrtf(x*x + y*y + image_z*image_z);
    float s3 = s*s*s;

    return to_mat3(s - s3*x*x, -s3*x*y, -s3*x*image_z,
                  -s3*x*y, s - s3*y*y, -s3*y*image_z,
                   0.0f,0.0f,0.0f);
}

__KERNEL__ void SpotApproximationFuse(__CONSTANTREF__ Params*  params,  __TEXTURE2D__ iChannel0, __TEXTURE2D_WRITE__ destinationTexture)
{
   DEFINE_KERNEL_ITERATORS_XY(fusion_x, fusion_y);

   if (fusion_x >= params->width || fusion_y >= params->height)
     return;

  float2 iResolution = to_float2(params->iResolution[0], params->iResolution[1]);
  float  iTime       = params->iTime;
  float4 iMouse      = to_float4(params->iMouse[0],params->iMouse[1],params->iMouse[2],params->iMouse[3]);
  int    iFrame      = params->iFrame;
  float4 fragColor   = to_float4_s(0.0f);
  float2 fragCoord   = to_float2(fusion_x,fusion_y);


  bool   NoSpots = params->NoSpots;
  bool   FORCE_TURNTABLE_MODE = params->FORCE_TURNTABLE_MODE;
  bool   SHOW_ITERATION_COUNT = params->SHOW_ITERATION_COUNT;
  bool   Tex = params->Tex;
  bool   SPOT_SDF_OPTIMIZED = params->SPOT_SDF_OPTIMIZED;
  float4 ColorBKG = to_float4(params->ColorBKG[0], params->ColorBKG[1], params->ColorBKG[2], params->ColorBKG[3]);
  float4 ColSpots = to_float4(params->ColSpots[0], params->ColSpots[1], params->ColSpots[2], params->ColSpots[3]);
  float4 ColNose = to_float4(params->ColNose[0], params->ColNose[1], params->ColNose[2], params->ColNose[3]);
  float4 ColHooves = to_float4(params->ColHooves[0], params->ColHooves[1], params->ColHooves[2], params->ColHooves[3]);
  float4 ColHorns = to_float4(params->ColHorns[0], params->ColHorns[1], params->ColHorns[2], params->ColHorns[3]);
  float4 ColEyes = to_float4(params->ColEyes[0], params->ColEyes[1], params->ColEyes[2], params->ColEyes[3]);
  float4 ColEyesHL = to_float4(params->ColEyesHL[0], params->ColEyesHL[1], params->ColEyesHL[2], params->ColEyesHL[3]);
  float4 ColEars = to_float4(params->ColEars[0], params->ColEars[1], params->ColEars[2], params->ColEars[3]);
  float4 ColNoStrils = to_float4(params->ColNoStrils[0], params->ColNoStrils[1], params->ColNoStrils[2], params->ColNoStrils[3]);
  float4 ColBase = to_float4(params->ColBase[0], params->ColBase[1], params->ColBase[2], params->ColBase[3]);
  float2 ViewDXY = to_float2(params->ViewDXY[0], params->ViewDXY[1]);
  float  ViewDZ = params->ViewDZ;
  float2 ViewXY = to_float2(params->ViewXY[0], params->ViewXY[1]);
  float  ViewZ = params->ViewZ;
  float  TURNTABLE_SPEED1 = params->TURNTABLE_SPEED1;
  float  TURNTABLE_SPEED2 = params->TURNTABLE_SPEED2;
  float  TURNTABLE_DEPTH = params->TURNTABLE_DEPTH;
  float  CAMERA_SHIFT_Y = params->CAMERA_SHIFT_Y;
  float  CAMERA_Z_DISTANCE = params->CAMERA_Z_DISTANCE;
  float  VIEW_ANGLE_FACTOR = params->VIEW_ANGLE_FACTOR;
  float  SPOT_SDF_OPTIMIZED_SCALE = params->SPOT_SDF_OPTIMIZED_SCALE;

  // --------

    float3 Colors[9] = {swi3(ColSpots,x,y,z), swi3(ColNose,x,y,z),swi3(ColHooves,x,y,z),swi3(ColHorns,x,y,z),swi3(ColEyes,x,y,z),swi3(ColEyesHL,x,y,z),swi3(ColEars,x,y,z),swi3(ColNoStrils,x,y,z),swi3(ColBase,x,y,z)};

    float ratio = iResolution.y/iResolution.x;

    fragCoord -= 0.5f*iResolution;

    mat3 rotation_matrix = make_camera_rotation_matrix(iMouse, iResolution, iTime, FORCE_TURNTABLE_MODE, TURNTABLE_SPEED1, TURNTABLE_SPEED2, TURNTABLE_DEPTH);

    float3 V = mul_mat3_f3(rotation_matrix , normalize(to_float3_aw(fragCoord, VIEW_ANGLE_FACTOR*iResolution.y)+to_float3_aw(ViewDXY*iResolution, ViewDZ*iResolution.y)));

    float3 ray_O = mul_mat3_f3(rotation_matrix , (to_float3(0.5f, 0.5f, -CAMERA_Z_DISTANCE) - to_float3(0.5f, 0.5f, 0.25f)) + to_float3(0, CAMERA_SHIFT_Y, 0)+to_float3_aw(ViewXY, ViewZ));

    mat3 J_proj = mul_mat3_mat3(rotation_matrix , projection_Jacobian(fragCoord.x, fragCoord.y, VIEW_ANGLE_FACTOR*iResolution.y));

    float3 color = swi3(ColorBKG,x,y,z);//BACKGROUND_COLOR;

    float Alpha = ColorBKG.w;

    int itr_count = 0;
    float t = ray_march_bisect(ray_O, V, &itr_count, SPOT_SDF_OPTIMIZED, SPOT_SDF_OPTIMIZED_SCALE); //!!!

    if (t < 1e18f) {
        float3 P = ray_O + t*V;

#ifdef SPOT_TEXTURE_EDGE_GRADIENT // antialias the texture

        float4 f_grad = to_float4_s(0.0f);

        int color_index = spot_get_color_index(P, NoSpots, &f_grad);

        float3 N;// = normalize(swi3(spot_sdf_and_gradient(P),x,y,z));
        if (SPOT_SDF_OPTIMIZED) N = normalize(swi3(spot_sdf_and_gradient_Optimize(ray_O + t*V, SPOT_SDF_OPTIMIZED_SCALE),x,y,z));
        else                    N = normalize(swi3(spot_sdf_and_gradient(P),x,y,z));


        float3 light = 0.5f * lighting_approx(N) + 0.1f;

        color = gamut_clip(light * spot_color_index_to_rgb(color_index, Colors, P, N, ratio, Tex, iChannel0));

        if (f_grad.w > -1e18f) {
            // Get combined Jacobian matrix (partial derivatives) for turning pixel coordinate into a camera ray,
            //      then intersecting that ray with the plane that locally approximates the surface.
            // This matrix allows computing the gradient of a function that defines the edge of the nearby shape
            //      (like an SDF, but does not give the distance to the edge, and the magnitude of the gradient is arbitrary).
            // The gradient will be used to estimate distance to edge, for anti-aliasing.
            J_proj = mul_mat3_mat3((mat3_add_mat3(outerProduct(-t / dot(V, N) * V, N) , to_mat3_f(t))) , J_proj);

            // At edges, where dot(V, N) > -1e-2, antialiasing is skipped
            //  (could skip a lot of calculations, but it probably wouldn't help performance because it only affects a small number of pixels)

            // Antialiasing is applied to clipped RGB values (but before conversion to sRGB)
            //      otherwise there would likely still be aliasing in brightly lit areas

            {
                // not using the built-in GLSL function "sign" because it seems to cause weird problems in Windows
                float d = dot(V, N) > -1e-2f ? (f_grad.w < 0.0f ? -1.0f : 1.0f) : f_grad.w / _fmaxf(1e-12f, length(mul_f3_mat3(swi3(f_grad,x,y,z) , J_proj)));

                if (d > -0.7f) {
                    color = _mix(color, gamut_clip(light * spot_color_index_to_rgb(color_index == SPOT_COLOR_NOSTRILS ? SPOT_COLOR_NOSE : SPOT_COLOR_BASE, Colors, P, N, ratio, Tex, iChannel0)),
                                        smoothstep(-0.7f, 0.7f, d));
                }
            }

            if (color_index == SPOT_COLOR_EYES) {
                f_grad = spot_get_eye_highlight_grad(P);

                float d = dot(V, N) > -1e-2f ? (f_grad.w < 0.0f ? -1.0f : 1.0f) : f_grad.w / _fmaxf(1e-12f, length(mul_f3_mat3(swi3(f_grad,x,y,z) , J_proj)));

                if (d < 0.7f) {
                    color = _mix(gamut_clip(light * spot_color_index_to_rgb(SPOT_COLOR_EYE_HIGHLIGHT, Colors, P, N, ratio, (bool)Tex, iChannel0)),
                                      color,
                                      smoothstep(-0.7f, 0.7f, d));
                }
            }

        }

#else // spot_get_color_index does not return distance and gradient, so don't antialias

        int color_index = spot_get_color_index(P, NoSpots);

        float3 N;// = normalize(swi3(spot_sdf_and_gradient(P),x,y,z));
        if (SPOT_SDF_OPTIMIZED) N = normalize(swi3(spot_sdf_and_gradient_Optimize(ray_O + t*V, SPOT_SDF_OPTIMIZED_SCALE),x,y,z));
        else                    N = normalize(swi3(spot_sdf_and_gradient(P),x,y,z));

        color = gamut_clip((0.5f * lighting_approx(N) + 0.1f) * spot_color_index_to_rgb(color_index, Colors, P, N, ratio, (bool)Tex, iChannel0));

#endif
    Alpha = 1.0f;
    }

    if (SHOW_ITERATION_COUNT)
    {
        if (itr_count >= 100)     color = to_float3(1,0,0);
        else if (itr_count >= 50) color = to_float3(1,1,0);
        else if (itr_count >= 20) color = to_float3(0,1,0);
        else if (itr_count >= 10) color = to_float3(0,1,1);
        else if (itr_count >= 5)  color = to_float3(0,0,1);
    }

    fragColor = to_float4_aw(linear_to_srgb(color), Alpha);

  _tex2DVec4Write(destinationTexture, fusion_x, fusion_y, fragColor);
}
]]
-- /*



