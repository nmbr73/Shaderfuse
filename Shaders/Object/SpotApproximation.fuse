  float  ViewZ;
  float  TURNTABLE_SPEED1;
  float  TURNTABLE_SPEED2;
  float  TURNTABLE_DEPTH;
  float  CAMERA_SHIFT_Y;
  float  CAMERA_Z_DISTANCE;
