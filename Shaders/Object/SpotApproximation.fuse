    InColNoStrilsColorG = self:AddInput("Green", "ColNoStrilsGreen", { INP_Default  = 0.1, IC_ControlID = 1, attrs})
    InColNoStrilsColorB = self:AddInput("Blue",  "ColNoStrilsBlue",  { INP_Default  = 0.2, IC_ControlID = 2, attrs})
