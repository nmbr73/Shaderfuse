          INP_Default        = 0.3,
      })

  InCAMERA_SHIFT_YSlider = self:AddInput("CAMERA_SHIFT_Y", "CAMERA_SHIFT_Y", {
          LINKID_DataType    = "Number",
          INPID_InputControl = "SliderControl",
          INP_MinScale       = -2.0,
