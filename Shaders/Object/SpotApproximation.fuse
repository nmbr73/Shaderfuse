    InColHoovesColorR = self:AddInput("Red",   "ColHoovesRed",   { INP_Default  = 0.1, IC_ControlID = 0, attrs})
    InColHoovesColorG = self:AddInput("Green", "ColHoovesGreen", { INP_Default  = 0.1, IC_ControlID = 1, attrs})
    InColHoovesColorB = self:AddInput("Blue",  "ColHoovesBlue",  { INP_Default  = 0.2, IC_ControlID = 2, attrs})
    InColHoovesColorA = self:AddInput("Alpha", "ColHoovesAlpha", { INP_Default  = 1.0, IC_ControlID = 3, attrs})

  self:EndControlNest()

  self:BeginControlNest("ColHorns", "ColHorns", true, {})

    ctrl_grp_cnt = (ctrl_grp_cnt==nil) and 1 or (ctrl_grp_cnt+1)

    attrs = {
      ICS_Name = "ColHorns",
      LINKID_DataType = "Number",
      INPID_InputControl = "ColorControl",
      INP_MinScale = 0.0,
      INP_MaxScale = 1.0,
      IC_ControlGroup = ctrl_grp_cnt,
    }

    InColHornsColorR = self:AddInput("Red",   "ColHornsRed",   { INP_Default  = 0.1, IC_ControlID = 0, attrs})
    InColHornsColorG = self:AddInput("Green", "ColHornsGreen", { INP_Default  = 0.1, IC_ControlID = 1, attrs})
    InColHornsColorB = self:AddInput("Blue",  "ColHornsBlue",  { INP_Default  = 0.2, IC_ControlID = 2, attrs})
    InColHornsColorA = self:AddInput("Alpha", "ColHornsAlpha", { INP_Default  = 1.0, IC_ControlID = 3, attrs})

  self:EndControlNest()

  self:BeginControlNest("ColEyes", "ColEyes", true, {})

    ctrl_grp_cnt = (ctrl_grp_cnt==nil) and 1 or (ctrl_grp_cnt+1)

